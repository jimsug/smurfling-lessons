{
  // Preview deploys only - production stays on GitHub Pages
  // (.github/workflows/deploy.yml). This Worker exists purely so PRs
  // targeting `development`/`main` get a *.workers.dev preview URL via
  // Cloudflare's git integration.
  "name": "smurfling-lessons-preview",
  "compatibility_date": "2026-07-23",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  },
  "preview_urls": true
}
