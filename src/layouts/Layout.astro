---
import '../styles/global.css'
import { getAbsoluteLocaleUrl } from 'astro:i18n'
import { locales, defaultLocale, type Locale } from '../i18n/locales'
import { useTranslations } from '../i18n/ui'
import { stripLocalePrefix, localizedPath } from '../i18n/paths'
import LanguageSwitcher from '../components/LanguageSwitcher.astro'

interface Props {
  title: string
  description?: string
}

const locale = (Astro.currentLocale as Locale) ?? defaultLocale
const t = useTranslations(locale)

const { title, description = t('meta.defaultDescription') } = Astro.props

const { path: canonicalPath } = stripLocalePrefix(Astro.url.pathname)
const home = localizedPath('/', locale)
const glossaryPath = localizedPath('/glossary/', locale)
const resourcesPath = localizedPath('/resources/', locale)
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {locales.map((code) => (
      <link rel="alternate" hreflang={code} href={getAbsoluteLocaleUrl(code, canonicalPath)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={getAbsoluteLocaleUrl(defaultLocale, canonicalPath)} />
    <link
      rel="preload"
      href="/fonts/inter-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/chakra-petch-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
    {/* Mark the document as JS-capable before paint so .js-only controls
        show without a flash, and stay hidden when JS is off. */}
    <script is:inline>
      document.documentElement.classList.add('js')
    </script>
  </head>
  <body class="flex min-h-dvh flex-col">
    <header class="border-b border-edge/70">
      <div
        class="mx-auto flex w-full max-w-3xl flex-wrap items-center justify-between gap-x-3 gap-y-2 px-4 py-4"
      >
        <a href={home} class="shrink-0 font-semibold tracking-wide text-glow">{t('site.name')}</a>
        <div class="flex items-center gap-4">
          <nav class="flex items-center gap-4 text-sm">
            <a href={glossaryPath} class="text-muted hover:text-glow">{t('nav.glossary')}</a>
            <a href={resourcesPath} class="text-muted hover:text-glow">{t('nav.resources')}</a>
          </nav>
          <LanguageSwitcher />
        </div>
      </div>
    </header>

    <main class="mx-auto w-full max-w-3xl flex-1 px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-edge/70 text-sm text-muted">
      <div class="mx-auto w-full max-w-3xl space-y-2 px-4 py-6">
        <nav class="flex flex-wrap gap-x-4 gap-y-1" aria-label={t('layout.footerAriaLabel')}>
          <a href={home} class="hover:text-glow">{t('nav.dashboard')}</a>
          <a href={glossaryPath} class="hover:text-glow">{t('nav.glossary')}</a>
          <a href={resourcesPath} class="hover:text-glow">{t('nav.resources')}</a>
        </nav>
        <p>
          {t('footer.inspiredBy')}{' '}
          <a href="https://smurfling.guide" class="text-resistance hover:text-glow"
            >smurfling.guide</a
          >.
        </p>
        <p>
          {t('footer.licensedPrefix')}{' '}
          <a
            href="https://creativecommons.org/licenses/by-sa/4.0/"
            class="text-resistance hover:text-glow">CC BY-SA 4.0</a
          >{t('footer.licenseSuffix')}
        </p>
      </div>
    </footer>

    <script
      type="application/json"
      id="i18n-strings"
      is:inline
      set:html={JSON.stringify({
        confirmReset: t('dashboard.confirmReset'),
        markComplete: t('lesson.markComplete'),
        completed: t('lesson.completed'),
        earned: t('badge.earned'),
        locked: t('badge.locked'),
      })}
    />
    <script>
      import '../scripts/locale.ts'
    </script>
  </body>
</html>
