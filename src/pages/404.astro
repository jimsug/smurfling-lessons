---
import Layout from '../layouts/Layout.astro'
import { defaultLocale, type Locale } from '../i18n/locales'
import { useTranslations } from '../i18n/ui'

const locale = (Astro.currentLocale as Locale) ?? defaultLocale
const t = useTranslations(locale)
---

<Layout title={`${t('notFound.pageTitle')} — ${t('site.name')}`}>
  <p class="eyebrow">{t('notFound.eyebrow')}</p>
  <h1 class="text-2xl font-bold text-fg">{t('notFound.title')}</h1>
  <p class="mt-2 text-muted">
    {t('notFound.body')}
  </p>
  <p class="mt-4">
    <a href="/" class="text-resistance hover:text-glow">{t('notFound.backLink')}</a>
  </p>
</Layout>
