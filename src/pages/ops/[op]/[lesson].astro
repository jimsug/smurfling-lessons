---
import Layout from '../../../layouts/Layout.astro'
import { render } from 'astro:content'
import { getOpsBySlug } from '../../../data/ops'
import { lessonHref, lessonSlug, lessonsForLocale } from '../../../lib/lessons'
import { lessonKey } from '../../../lib/progress'
import { defaultLocale, type Locale } from '../../../i18n/locales'
import { useTranslations } from '../../../i18n/ui'
import { localizedPath } from '../../../i18n/paths'
import Lvl from '../../../components/Lvl.astro'
import Medal from '../../../components/Medal.astro'
import Term from '../../../components/Term.astro'
import type { GetStaticPaths } from 'astro'

// getStaticPaths is extracted into its own module scope by Astro's
// compiler: it cannot see plain consts declared elsewhere in this
// frontmatter, only imports (hence `defaultLocale` rather than a local alias).
export const getStaticPaths = (async () => {
  const list = await lessonsForLocale(defaultLocale)
  return list.map(({ entry, op, slug, title, summary, isFallback }, i) => {
    const prev = list[i - 1]
    const next = list[i + 1]
    return {
      params: { op, lesson: slug },
      props: {
        entry,
        title,
        summary,
        isFallback,
        prev: prev
          ? { href: lessonHref(defaultLocale, prev.op, prev.slug), title: prev.title }
          : null,
        next: next
          ? { href: lessonHref(defaultLocale, next.op, next.slug), title: next.title }
          : null,
      },
    }
  })
}) satisfies GetStaticPaths

const { entry, title, summary, isFallback, prev, next } = Astro.props
const locale = (Astro.currentLocale as Locale) ?? defaultLocale
const t = useTranslations(locale)
const { Content } = await render(entry)
const op = getOpsBySlug(defaultLocale)[entry.data.op]
---

<Layout
  title={`${title} — ${t('site.name')}`}
  description={summary}
>
  <nav class="text-xs text-muted" aria-label={t('nav.breadcrumbAriaLabel')}>
    <a href={localizedPath('/', locale)} class="hover:text-glow">{t('nav.dashboard')}</a>
    <span aria-hidden="true">&nbsp;/&nbsp;</span>
    <a href={localizedPath(`/ops/${op.slug}/`, locale)} class="hover:text-glow">{op.shortTitle}</a>
    <span aria-hidden="true">&nbsp;/&nbsp;</span>
    <span aria-current="page">{t('lesson.breadcrumbLabel', { order: entry.data.order })}</span>
  </nav>

  <h1 class="mt-3 text-2xl font-bold text-fg">{title}</h1>
  <p class="mt-1 text-muted">{summary}</p>

  {
    isFallback && (
      <p class="mt-3 rounded-md border border-edge bg-panel px-3 py-2 text-sm text-muted">
        {t('lesson.notYetTranslated')}
      </p>
    )
  }

  <button
    type="button"
    class="mark-complete js-only mt-4"
    data-mark-complete
    data-lesson-key={lessonKey(entry.data.op, lessonSlug(entry))}
    aria-pressed="false"
  >
    <svg class="check" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
      <path
        d="M2 8.5 L6.5 13 L14 3.5"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
    <span data-mark-label>{t('lesson.markComplete')}</span>
  </button>

  <article class="lesson-prose mt-8">
    <Content components={{ Lvl, Medal, Term }} />
  </article>

  <nav
    class="mt-12 flex gap-3 border-t border-edge/60 pt-6"
    aria-label={t('lesson.navigationAriaLabel')}
  >
    {
      prev ? (
        <a href={prev.href} class="lesson-nav group flex-1">
          <span class="block text-xs text-muted">{t('lesson.previous')}</span>
          <span class="mt-0.5 block text-sm font-medium text-fg group-hover:text-glow">
            {prev.title}
          </span>
        </a>
      ) : (
        <span class="flex-1" />
      )
    }
    {
      next ? (
        <a href={next.href} class="lesson-nav group flex-1 text-right">
          <span class="block text-xs text-muted">{t('lesson.next')}</span>
          <span class="mt-0.5 block text-sm font-medium text-fg group-hover:text-glow">
            {next.title}
          </span>
        </a>
      ) : (
        <span class="flex-1" />
      )
    }
  </nav>

  <script>
    import '../../../scripts/lesson.ts'
  </script>
</Layout>

<style>
  .mark-complete {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--color-resistance);
    border-radius: 0.4rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-glow);
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }
  .mark-complete .check {
    opacity: 0.35;
    transition: opacity 0.2s ease;
  }
  .mark-complete.is-done {
    background-color: var(--color-resistance);
    border-color: var(--color-resistance);
    color: var(--color-night);
  }
  .mark-complete.is-done .check {
    opacity: 1;
  }

  .lesson-nav {
    display: block;
    border: 1px solid var(--color-edge);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    background-color: var(--color-panel);
    transition: border-color 0.2s ease;
  }
  .lesson-nav:hover {
    border-color: color-mix(in oklab, var(--color-resistance) 60%, transparent);
  }
</style>
