---
import Layout from '../../../layouts/Layout.astro'
import Badge from '../../../components/Badge.astro'
import { getOps } from '../../../data/ops'
import { lessonHref, lessonsForLocale } from '../../../lib/lessons'
import { lessonKey } from '../../../lib/progress'
import { defaultLocale, type Locale } from '../../../i18n/locales'
import { useTranslations } from '../../../i18n/ui'
import type { GetStaticPaths } from 'astro'

// getStaticPaths is extracted into its own module scope by Astro's
// compiler: it cannot see plain consts declared elsewhere in this
// frontmatter, only imports (hence `defaultLocale` rather than a local alias).
export const getStaticPaths = (() =>
  getOps(defaultLocale).map((op) => ({
    params: { op: op.slug },
    props: { op },
  }))) satisfies GetStaticPaths

const { op } = Astro.props
const locale = (Astro.currentLocale as Locale) ?? defaultLocale
const t = useTranslations(locale)
const lessons = (await lessonsForLocale(defaultLocale)).filter(
  (lesson) => lesson.op === op.slug,
)

const sortedOps = [...getOps(defaultLocale)].sort((a, b) => a.order - b.order)
const opIndex = sortedOps.findIndex((o) => o.slug === op.slug)
const prevOp = sortedOps[opIndex - 1] ?? null
const nextOp = sortedOps[opIndex + 1] ?? null
---

<Layout title={`${op.title} — Smurfling Guide`} description={op.description}>
  <nav class="text-xs text-muted" aria-label="Breadcrumb">
    <a href="/" class="hover:text-glow">{t('nav.dashboard')}</a>
    <span aria-hidden="true">&nbsp;/&nbsp;</span>
    <span aria-current="page">{t('op.breadcrumbLabel', { order: op.order })}</span>
  </nav>

  <header class="mt-3 flex items-center gap-4">
    <Badge slug={op.slug} order={op.order} shortTitle={op.shortTitle} size="lg" />
    <div class="min-w-0">
      <h1 class="text-xl font-bold text-fg">{op.shortTitle}</h1>
      <p class="mt-1 text-sm text-muted">{op.description}</p>
      <p class="js-only mt-2 text-xs text-muted">
        <span data-op-count>0/{lessons.length}</span> {t('op.lessonsCompleteSuffix')}
      </p>
    </div>
  </header>

  <ul
    class="mt-6 divide-y divide-edge/60 overflow-hidden rounded-lg border border-edge"
  >
    {
      lessons.map((lesson) => (
        <li class="flex items-start gap-3 bg-panel p-4">
          <label class="js-only -m-2.5 flex items-center p-2.5">
            <input
              type="checkbox"
              data-lesson-key={lessonKey(lesson.op, lesson.slug)}
              class="size-6 accent-resistance"
              aria-label={t('op.markCompleteAriaLabel', { title: lesson.entry.data.title })}
            />
          </label>
          <div class="min-w-0">
            <a
              href={lessonHref(locale, lesson.op, lesson.slug)}
              class="font-medium text-fg hover:text-glow"
            >
              {lesson.entry.data.order}. {lesson.entry.data.title}
            </a>
            <p class="mt-0.5 text-sm text-muted">{lesson.entry.data.summary}</p>
          </div>
        </li>
      ))
    }
  </ul>

  <p class="js-only mt-4 text-xs text-muted">{t('progress.savedNote')}</p>

  <nav
    class="mt-10 flex gap-3 border-t border-edge/60 pt-6"
    aria-label={t('op.adjacentOpsAriaLabel')}
  >
    {
      prevOp ? (
        <a
          href={`/ops/${prevOp.slug}/`}
          class="flex-1 rounded-lg border border-edge bg-panel p-3 transition hover:border-resistance/60"
        >
          <span class="block text-xs text-muted">{t('op.previousOp')}</span>
          <span class="mt-0.5 block font-display text-sm font-semibold text-fg">
            {prevOp.shortTitle}
          </span>
        </a>
      ) : (
        <span class="flex-1" />
      )
    }
    {
      nextOp ? (
        <a
          href={`/ops/${nextOp.slug}/`}
          class="flex-1 rounded-lg border border-edge bg-panel p-3 text-right transition hover:border-resistance/60"
        >
          <span class="block text-xs text-muted">{t('op.nextOp')}</span>
          <span class="mt-0.5 block font-display text-sm font-semibold text-fg">
            {nextOp.shortTitle}
          </span>
        </a>
      ) : (
        <span class="flex-1" />
      )
    }
  </nav>

  <script>
    import '../../../scripts/op.ts'
  </script>
</Layout>
