---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { glossary, termLesson } from '../data/glossary'

const sorted = [...glossary].sort((a, b) => a.term.localeCompare(b.term))
const lessons = await getCollection('lessons')
const lessonTitle = new Map(lessons.map((lesson) => [lesson.id, lesson.data.title]))
---

<Layout
  title="Glossary — Smurfling Guide"
  description="Plain-language definitions of the Ingress terms used in this guide."
>
  <p class="eyebrow">Reference</p>
  <h1 class="text-2xl font-bold text-fg">Glossary</h1>
  <p class="mt-1 text-muted">
    Plain-language definitions of the terms used across the guide. Each links to
    the lesson that covers it.
  </p>

  <div class="js-only mt-4">
    <input
      type="search"
      data-glossary-search
      placeholder="Filter terms…"
      aria-label="Filter glossary terms"
      autocomplete="off"
      class="w-full rounded-md border border-edge bg-panel px-3 py-2 text-fg placeholder:text-muted"
    />
    <p class="mt-2 text-sm text-muted" data-glossary-empty hidden>No terms match.</p>
  </div>

  <dl class="mt-6 divide-y divide-edge/60">
    {
      sorted.map((entry) => {
        const lessonId = termLesson[entry.id]
        const title = lessonId ? lessonTitle.get(lessonId) : undefined
        return (
          <div
            id={entry.id}
            data-term
            data-term-text={`${entry.term} ${entry.definition}`.toLowerCase()}
            class="scroll-mt-24 py-3"
          >
            <dt class="font-semibold text-fg">{entry.term}</dt>
            <dd class="mt-0.5 text-sm text-muted">{entry.definition}</dd>
            {title && (
              <dd class="mt-1 text-xs">
                <a href={`/ops/${lessonId}/`} class="text-resistance hover:text-glow">
                  Covered in {title} →
                </a>
              </dd>
            )}
          </div>
        )
      })
    }
  </dl>

  <script>
    import '../scripts/glossary.ts'
  </script>
</Layout>
