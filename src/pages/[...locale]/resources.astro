---
import Layout from '../../layouts/Layout.astro'
import { locales, defaultLocale, type Locale } from '../../i18n/locales'
import { useTranslations, type UIKey } from '../../i18n/ui'
import type { GetStaticPaths } from 'astro'

export const getStaticPaths = (() =>
  locales.map((locale) => ({
    params: { locale: locale === defaultLocale ? undefined : locale },
  }))) satisfies GetStaticPaths

const locale = (Astro.currentLocale as Locale) ?? defaultLocale
const t = useTranslations(locale)

interface LinkItem {
  href: string
  label: string
  noteKey: UIKey
}

const official: LinkItem[] = [
  { href: 'https://ingress.com', label: 'ingress.com', noteKey: 'resources.official.ingress.note' },
  { href: 'https://intel.ingress.com', label: 'intel.ingress.com', noteKey: 'resources.official.intel.note' },
  {
    href: 'https://wayfarer.nianticlabs.com',
    label: 'Niantic Wayfarer',
    noteKey: 'resources.official.wayfarer.note',
  },
  { href: 'https://support.ingress.com', label: 'Ingress Help', noteKey: 'resources.official.help.note' },
]

const community: LinkItem[] = [
  { href: 'https://fevgames.net', label: 'Fev Games', noteKey: 'resources.community.fevgames.note' },
  { href: 'https://bannergress.com', label: 'Bannergress', noteKey: 'resources.community.bannergress.note' },
]
---

<Layout title={`${t('resources.title')} — ${t('site.name')}`} description={t('resources.metaDescription')}>
  <p class="eyebrow">{t('resources.eyebrow')}</p>
  <h1 class="text-2xl font-bold text-fg">{t('resources.title')}</h1>
  <p class="mt-1 text-muted">
    {t('resources.intro')}
  </p>

  <section class="mt-8">
    <h2 class="font-semibold text-fg">{t('resources.findTeam.heading')}</h2>
    <p class="mt-1 text-sm text-muted">
      {t('resources.findTeam.body')}
    </p>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-muted">
      <li>{t('resources.findTeam.step1')}</li>
      <li>{t('resources.findTeam.step2')}</li>
      <li>{t('resources.findTeam.step3')}</li>
    </ul>
  </section>

  <section class="mt-8">
    <h2 class="font-semibold text-fg">{t('resources.official.heading')}</h2>
    <ul class="mt-2 space-y-1 text-sm text-muted">
      {
        official.map((item) => (
          <li>
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-resistance hover:text-glow"
            >
              {item.label}
            </a>
            {` — ${t(item.noteKey)}.`}
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-8">
    <h2 class="font-semibold text-fg">{t('resources.community.heading')}</h2>
    <p class="mt-1 text-sm text-muted">
      {t('resources.community.body')}
    </p>
    <ul class="mt-2 space-y-1 text-sm text-muted">
      {
        community.map((item) => (
          <li>
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-resistance hover:text-glow"
            >
              {item.label}
            </a>
            {` — ${t(item.noteKey)}.`}
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-8">
    <h2 class="font-semibold text-fg">{t('resources.about.heading')}</h2>
    <p class="mt-1 text-sm text-muted">
      {t('footer.inspiredBy')}{' '}
      <a href="https://smurfling.guide" class="text-resistance hover:text-glow"
        >smurfling.guide</a
      >.{' '}
      {t('footer.licensedPrefix')}{' '}
      <a href="https://creativecommons.org/licenses/by-sa/4.0/" class="text-resistance hover:text-glow"
        >CC BY-SA 4.0</a
      >{t('footer.licenseSuffix')}
    </p>
  </section>
</Layout>
