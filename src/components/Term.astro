---
import { getGlossaryById } from '../data/glossary'
import { uid } from '../lib/uid'
import { stripLocalePrefix, localizedPath } from '../i18n/paths'
import { useTranslations } from '../i18n/ui'

interface Props {
  id: string
}

const { id } = Astro.props
// Invoked from inside rendered MDX prose (via <Content components={{ Term }} />),
// where Astro.currentLocale is documented as unreliable. Astro.url stays
// accessible here, so locale is derived from the path instead.
const { locale } = stripLocalePrefix(Astro.url.pathname)
const t = useTranslations(locale)
const entry = getGlossaryById(locale)[id]
const popId = uid('gd')
const glossaryHref = localizedPath('/glossary/', locale)
---

{
  entry ? (
    <span class="term-wrap">
      <button type="button" class="term" popovertarget={popId}>
        <slot>{entry.term}</slot><span class="sr-only">{t('term.definitionSuffix')}</span>
      </button>
      <span popover="auto" id={popId} class="term-pop">
        <strong class="term-pop-title">{entry.term}</strong>
        <span class="term-pop-def">{entry.definition}</span>
        <a class="term-pop-link" href={`${glossaryHref}#${id}`}>{t('term.openGlossary')}</a>
      </span>
    </span>
  ) : (
    <slot>{id}</slot>
  )
}
