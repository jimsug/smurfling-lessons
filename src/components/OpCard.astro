---
import type { Op } from '../data/ops'

interface Props {
  op: Op
  lessonCount: number
}

const { op, lessonCount } = Astro.props
---

<a
  href={`/ops/${op.slug}/`}
  class="op-card flex items-center gap-4 rounded-xl border border-edge bg-panel p-4 transition hover:border-resistance/60"
  data-op-card={op.slug}
>
  <span class="op-num" aria-hidden="true">{op.order}</span>
  <span class="min-w-0 flex-1">
    <span class="block font-display font-semibold text-fg">{op.shortTitle}</span>
    <span class="mt-0.5 block text-sm text-muted">{op.description}</span>
  </span>
  <span class="js-only flex-none text-right">
    <span
      class="block font-display text-sm font-semibold tabular-nums text-glow"
      data-op-count>0/{lessonCount}</span
    >
    <span class="block text-[10px] tracking-wide text-muted uppercase">done</span>
  </span>
</a>

<style>
  .op-card.is-complete {
    border-color: var(--color-glow);
  }
</style>
