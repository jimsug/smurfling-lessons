---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { locales, localeNames, defaultLocale, type Locale } from '../i18n/locales'
import { stripLocalePrefix } from '../i18n/paths'

const locale = (Astro.currentLocale as Locale) ?? defaultLocale
const { path } = stripLocalePrefix(Astro.url.pathname)
---

{
  locales.length > 1 && (
    <nav aria-label="Language" class="flex flex-wrap gap-x-3 gap-y-1 text-sm">
      {locales.map((code) =>
        code === locale ? (
          <span aria-current="true" class="text-glow">
            {localeNames[code]}
          </span>
        ) : (
          <a href={getRelativeLocaleUrl(code, path)} class="text-muted hover:text-glow">
            {localeNames[code]}
          </a>
        ),
      )}
    </nav>
  )
}
