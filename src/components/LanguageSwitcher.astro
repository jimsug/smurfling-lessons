---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { locales, localeNames, defaultLocale, type Locale } from '../i18n/locales'
import { stripLocalePrefix } from '../i18n/paths'

const locale = (Astro.currentLocale as Locale) ?? defaultLocale
const { path } = stripLocalePrefix(Astro.url.pathname)
---

{
  locales.length > 1 && (
    <select
      data-language-switcher
      aria-label="Language"
      class="rounded-md border border-edge bg-panel px-2 py-1 text-sm text-muted hover:text-glow focus:text-glow focus:outline-none focus:ring-1 focus:ring-resistance"
    >
      {locales.map((code) => (
        <option value={getRelativeLocaleUrl(code, path)} selected={code === locale}>
          {localeNames[code]}
        </option>
      ))}
    </select>
  )
}

<script>
  import '../scripts/language-switcher.ts'
</script>
